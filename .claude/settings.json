{
  "cleanupPeriodDays": 28,
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "512000",
    "ECC_GATEGUARD": "off",
    "ECC_CONTEXT_MONITOR_COST_WARNINGS": "false",
    "ECC_DISABLED_HOOKS": "stop:cost-tracker"
  },
  "permissions": {
    "allow": [
      "Bash(git *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git push --force *)",
      "Bash(chmod 777 *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ],
    "defaultMode": "auto"
  },
  "model": "claude-fable-5[1m]",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "codex@openai-codex": true,
    "ecc@ecc": true,
    "figma@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "ecc": {
      "source": {
        "source": "git",
        "url": "https://github.com/affaan-m/ECC.git"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "language": "japanese",
  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "github.com",
        "*.npmjs.org",
        "undraw.co",
        "unsplash.com",
        "images.unsplash.com",
        "api.unsplash.com",
        "*.rackcdn.com"
      ],
      "allowManagedDomainsOnly": true
    },
    "filesystem": {
      "denyRead": [
        "~/.aws/credentials",
        "~/.ssh"
      ]
    },
    "excludedCommands": [
      "git",
      "git *",
      "docker",
      "docker *"
    ]
  },
  "effortLevel": "xhigh",
  "voice": {
    "enabled": false,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": false,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": false
}
